{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/managing-research-plans/scripts/signoff_gate.py\"",
            "timeout": 1800
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/managing-research-plans/scripts/check_update.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
